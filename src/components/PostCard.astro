---
import IconLink from "./IconLink.astro";
import Collapse from "./Collapse.astro";
import BetteruptimeStatus from "./BetteruptimeStatus.astro";
import type { Repo, Post } from "../types";
import Image from "astro/components/Image.astro";

interface Props {
  post: Post;
  repo: Repo | null;
  idSuffix?: string;
}

const { post, repo, idSuffix = "" } = Astro.props;
const f = post.frontmatter;
const slug = f.abbrlink && f.title
  ? `${f.abbrlink}-${f.title.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fff]+/g, "-").replace(/^-+|-+$/g, "")}`
  : f.abbrlink || "";
const total = repo?.languages?.reduce((s, l) => s + l.bytes, 0) ?? 0;
const langs =
  repo?.languages
    ?.map((l) => ({ ...l, pct: (l.bytes / total) * 100 }))
    .filter((l) => l.pct >= 1) ?? [];
const hasCover = !!f.index_img;
const coverAlt = hasCover
  ? f.index_img!.split("/").pop()!.replace(/\.[^.]+$/, "")
  : "";
---

<style>
  /* 普通 border 边缘像素锯齿 */
  .smooth-border {
    box-shadow: 0 0 0 1.3px #e2e0e0;
    border-radius: 5px;
  }
</style>

<article class="card bg-card smooth-border postcard-card
                min-h-60 max-h-60 has-checked:max-h-200
                relative flex flex-col group
                transition-[max-height] ease-out overflow-hidden" id={slug + idSuffix}>
  <!-- 内容：flex-1 撑满卡片，z-10 浮在封面上 -->
  <div class="p-5 text-xs text-base-content/60 flex-1 min-h-60 flex flex-col relative z-10">
    {
      f.status && (
        <div class="flex items-baseline gap-2 font-mono font-bold text-xs">
          <span
            aria-label={f.status}
            class={`status ${
              {
                active: "status-success",
                done: "status-info",
                archived: "status-neutral",
              }[f.status]
            }`}
          />
          <span class={`uppercase ${
              {
                active: "text-success/80",
                done: "text-info/80",
                archived: "text-base-content/80",
              }[f.status]
            }`}>{f.status}</span>
        </div>
      )
    }

    {f.title && <h2 class="text-xl text-base-content font-bold leading-tight mt-2">
      <a href={"#" + slug}>{f.title}</a>
    </h2>}
    {f.date && <div class="mt-1.5">{f.date}</div>}

    <Collapse>
      <div class="mt-2.5 prose prose-slate prose-sm">
        <post.Content />
      </div>
    </Collapse>

    {f.betteruptime && (
      <BetteruptimeStatus host={f.betteruptime} />
    )}

    {
      langs.length > 1 && (
        <div class="flex h-1 rounded-full mt-4 shrink-0">
          {langs.map((l) => (
            <span style={{ width: l.pct + "%", backgroundColor: l.color }} />
          ))}
        </div>
      )
    }

    <!-- 一排 icon：右侧 mask 渐变消隐，溢出时在 repo/live 按钮前自然淡出 -->
    <div class="flex items-center gap-3 mt-3 *:shrink-0 overflow-clip not-has-[*]:hidden shrink-0
                mask-[linear-gradient(to_right,black,black_calc(100%-120px),transparent)]">
      {
        repo && (
          <span title="Stars">
            <svg
              class="size-3.5 fill-current shrink-0 inline"
              viewBox="0 0 16 16"
            >
              <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Zm0 2.445L6.615 5.5a.75.75 0 0 1-.564.41l-3.097.45 2.24 2.184a.75.75 0 0 1 .216.664l-.528 3.084 2.769-1.456a.75.75 0 0 1 .698 0l2.77 1.456-.53-3.084a.75.75 0 0 1 .216-.664l2.24-2.183-3.096-.45a.75.75 0 0 1-.564-.41L8 2.694Z"></path>
            </svg>
            {repo.stars}
          </span>
          <span title="Forks">
            <svg
              class="size-3.5 fill-current shrink-0 inline"
              viewBox="0 0 16 16"
            >
              <path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"></path>
            </svg>
            {repo.forks}
          </span>
        )
      }
      {
        repo?.license && (
          <a title="License"
            href={`${f.repo}/blob/${repo.defaultBranch}/LICENSE`}
            target="_blank"
            rel="noopener">
            <svg
              class="size-3.5 fill-current shrink-0 inline"
              viewBox="0 0 16 16"
            >
              <path d="M8.75.75V2h.985c.304 0 .603.08.867.231l1.29.736c.038.022.08.033.124.033h2.234a.75.75 0 0 1 0 1.5h-.427l2.111 4.692a.75.75 0 0 1-.154.838l-.53-.53.529.531-.001.002-.002.002-.006.006-.006.005-.01.01-.045.04c-.21.176-.441.327-.686.45C14.556 10.78 13.88 11 13 11a4.498 4.498 0 0 1-2.023-.454 3.544 3.544 0 0 1-.686-.45l-.045-.04-.016-.015-.006-.006-.004-.004v-.001a.75.75 0 0 1-.154-.838L12.178 4.5h-.162c-.305 0-.604-.079-.868-.231l-1.29-.736a.245.245 0 0 0-.124-.033H8.75V13h2.5a.75.75 0 0 1 0 1.5h-6.5a.75.75 0 0 1 0-1.5h2.5V3.5h-.984a.245.245 0 0 0-.124.033l-1.289.737c-.265.15-.564.23-.869.23h-.162l2.112 4.692a.75.75 0 0 1-.154.838l-.53-.53.529.531-.001.002-.002.002-.006.006-.016.015-.045.04c-.21.176-.441.327-.686.45C4.556 10.78 3.88 11 3 11a4.498 4.498 0 0 1-2.023-.454 3.544 3.544 0 0 1-.686-.45l-.045-.04-.016-.015-.006-.006-.004-.004v-.001a.75.75 0 0 1-.154-.838L2.178 4.5H1.75a.75.75 0 0 1 0-1.5h2.234a.249.249 0 0 0 .125-.033l1.288-.737c.265-.15.564-.23.869-.23h.984V.75a.75.75 0 0 1 1.5 0Zm2.945 8.477c.285.135.718.273 1.305.273s1.02-.138 1.305-.273L13 6.327Zm-10 0c.285.135.718.273 1.305.273s1.02-.138 1.305-.273L3 6.327Z" />
            </svg>
            {repo.license}
          </a>
        )
      }
      {
        langs
          .filter((l) => l.pct >= 3)
          .slice(0, 3)
          .map((l) => (
            <span title={`${l.name} ${l.pct.toFixed(1)}%`}>
              <i
                class="size-2 rounded-sm inline-block mr-0.5"
                style={{ backgroundColor: l.color }}
              />
              {l.name}
            </span>
          ))
      }
    </div>

    <!-- 右下角 IconLink -->
    <div class="absolute flex bottom-3 right-3 z-10">
      <div class="flex gap-2 font-mono">
      {
        f.bilibili && (
          <IconLink href={f.bilibili} class="bili-link">
            <svg class="size-3 fill-current" viewBox="0 0 24 24">
              <path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44l.16.213h5.16l.16-.213 2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.893v7.36c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.36c-.017-.764-.28-1.395-.786-1.893-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.387-.947.258-.257.574-.386.947-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.387-.947.258-.257.574-.386.947-.386z"/>
            </svg>
            bili
          </IconLink>
        )
      }
      {
        f.repo && (
          <IconLink href={f.repo} class="repo-link">
            <svg class="size-3 fill-current" viewBox="0 0 16 16">
              <path d="M2 2.5A2.5 2.5 0 014.5 0h8.75a.75.75 0 01.75.75v12.5a.75.75 0 01-.75.75h-2.5a.75.75 0 110-1.5h1.75v-2h-8a1 1 0 00-.714 1.7.75.75 0 01-1.072 1.05A2.495 2.495 0 012 11.5v-9zm10.5-1h-8a1 1 0 00-1 1v6.708A2.486 2.486 0 014.5 9h8V1.5zM5 12.25v3.25a.25.25 0 00.4.2l1.45-1.087a.25.25 0 01.3 0L8.6 15.7a.25.25 0 00.4-.2v-3.25a.25.25 0 00-.25-.25h-3.5a.25.25 0 00-.25.25z" />
            </svg>
            repo
          </IconLink>
        )
      }
      {
        f.url && (
          <IconLink href={f.url} class="live-link">
            <svg class="size-3 fill-current" viewBox="0 0 16 16">
              <path d="M3.75 2h3.5a.75.75 0 0 1 0 1.5h-3.5a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-3.5a.75.75 0 0 1 1.5 0v3.5A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.25v-8.5C2 2.784 2.784 2 3.75 2Zm6.854-1h4.146a.25.25 0 0 1 .25.25v4.146a.25.25 0 0 1-.427.177L13.03 4.03 9.28 7.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.75-3.75-1.543-1.543A.25.25 0 0 1 10.604 1Z" />
            </svg>
            live
          </IconLink>
        )
      }
      </div>
    </div>

    <!-- 点任意区域也可进，优先级从右到左 live > repo -->
    <!-- <a
      class="absolute inset-0"
      href={f.url || f.repo}
      target="_blank"
      rel="noopener"/> -->
  </div>
  <!-- 封面：在内容之后流内，收起时 -mt-60 上拉覆盖整卡作为背景，展开时 mt-0 自然下移到内容下方 -->
  {
    hasCover && (
      <div class="relative
                  -mt-60 group-has-checked:mt-0
                  transition-[margin-top] ease-out">
        <Image
          inferSize
          src={f.index_img!}
          alt={coverAlt}
          class="w-full h-auto block"
        />
        <div class="absolute inset-0 bg-base-100/80
                    opacity-100 group-has-checked:opacity-0 transition-opacity" />
      </div>
    )
  }
</article>

<style is:global>
  @keyframes highlight-flash {
    0%   { box-shadow: 0 0 0 0 var(--color-accent); }
    50%  { box-shadow: 0 0 0 4px var(--color-accent); }
    100% { box-shadow: 0 0 0 0 var(--color-accent); }
  }
  .highlight-flash {
    animation: highlight-flash 0.6s ease-out 0.6s 5;
  }

  /* 悬停卡片任意位置 → 右下角最右侧链接高亮 (live > repo > bili) */
  .postcard-card:hover :last-child:is(.bili-link, .repo-link, .live-link) {
    color: var(--color-accent);
    text-decoration-line: underline;
  }
  /* 直接悬停 bili/repo → 更右侧链接退让 */
  .postcard-card:has(.bili-link:hover) :last-child:is(.bili-link, .repo-link, .live-link):not(:hover),
  .postcard-card:has(.repo-link:hover) :last-child:is(.repo-link, .live-link):not(:hover) {
    color: inherit;
    text-decoration-line: none;
  }
</style>
