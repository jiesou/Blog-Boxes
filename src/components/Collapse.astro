<!--
  Collapse — 折叠内容区。
  flex-1 min-h-0：撑满卡片剩余垂直空间，使卡片保持固定 height。
  底部消隐用 mask（文字自身透明度），--fade 控制消隐高度，展开时淡出为 0。
-->
<style is:global>
  @property --fade {
    syntax: '<length>';
    inherits: false;
    initial-value: 0px;
  }
</style>
<div class="group relative flex-1 min-h-0 flex flex-col">
  <!-- 内容区：撑满裁剪窗口，底部 mask 渐变消隐。
       收起 --fade=48px 在窗口底部遮裁断处；展开 --fade=0 消隐淡出。 -->
  <div class="relative overflow-hidden flex-1 min-h-0
              [--fade:48px] group-has-checked:[--fade:0px]
              [mask-image:linear-gradient(to_bottom,black_calc(100%_-_var(--fade)),transparent)]
              transition-[--fade] duration-300 ease-out">
    <slot />
  </div>

  <!-- label = 可点击区域 + 右侧 daisyUI swap (+/-)。
       始终覆盖整个内容区：点击任意位置展开/收起。 -->
  <label
    class="absolute inset-0 z-10 flex items-end justify-end cursor-pointer"
    aria-label="展开/收起"
  >
    <span class="swap">
      <input type="checkbox" />
      <span class="swap-on">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M5 11.5H19V12.5H5Z" fill="currentColor"></path>
        </svg>
      </span>
      <span class="swap-off">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12.5 11.5H19V12.5H12.5V19H11.5V12.5H5V11.5H11.5V5H12.5V11.5Z" fill="currentColor"></path>
        </svg>
      </span>
    </span>
  </label>
</div>
