<!--
  Collapse — 折叠内容区。
  max-height 单维度动画 + overflow-hidden 物理裁剪 + mask 视觉渐隐。
  mask 挂在外层：has-checked 才能匹配到内层 label 里的 checkbox，
  渐隐位置 = 可见区底部，不受内容真实高度影响。
-->
<div
  class="relative
         max-h-46 has-checked:max-h-[100rem]
         overflow-hidden
         [--fade:32px] has-checked:[--fade:0px]
         mask-[linear-gradient(to_bottom,black_calc(100%-var(--fade)),transparent)]
         transition-[max-height,--fade] duration-300 ease-in-out"
>
  <slot />

  <label class="swap absolute top-2 right-2" aria-label="展开/收起">
    <input type="checkbox" />
    <!-- - -->
    <span class="swap-on">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path d="M5 11.5H19V12.5H5Z" fill="currentColor"></path>
      </svg>
    </span>
    <!-- + -->
    <span class="swap-off">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
        <path
          d="M12.5 11.5H19V12.5H12.5V19H11.5V12.5H5V11.5H11.5V5H12.5V11.5Z"
          fill="currentColor"></path>
      </svg>
    </span>
  </label>
</div>

<style is:global>
  @property --fade {
    syntax: "<length>";
    inherits: false;
    initial-value: 0px;
  }
</style>
