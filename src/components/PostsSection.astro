---
import type { Post, Repo } from "../types";
import PostCard from "./PostCard.astro";

interface Props {
  items: { post: Post; repo: Repo | null }[];
}

const { items } = Astro.props;

const NUM_COLS = 4;
const cols: { post: Post; repo: Repo | null }[][] = Array.from({ length: NUM_COLS }, () => []);
items.forEach((item, i) => cols[i % NUM_COLS].push(item));
---

<div class="p-12.5 max-md:p-6.5">
  <!-- 移动端: 平铺时间序列表 -->
  <div class="flex flex-col gap-5 sm:hidden">
    {items.map(({ post, repo }) => <PostCard post={post} repo={repo} />)}
  </div>

  <!-- sm+: 独立列容器，展开放大只影响本列 -->
  <div class="hidden sm:flex gap-5 xl:gap-10">
    {cols.map((col, ci) => (
      <div class="flex-1 flex flex-col gap-5 xl:gap-10">
        {col.map(({ post, repo }) => <PostCard post={post} repo={repo} />)}
      </div>
    ))}
  </div>
</div>
